# ============================================================
# DocMind AI — Gitignore
# ============================================================

# Environment secrets — NEVER commit
.env
.env.local
.env.production
.env*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# Uploads & generated files (too large for git)
backend/uploads/
backend/docmind.db

# Node
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
*.swp

# IDE
.vscode/
.idea/
*.sublime-project
